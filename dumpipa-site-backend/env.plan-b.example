# ============================================
# 方案B：分站后端对接Mac主站后端
# 使用方法：复制此文件为 .env 并修改配置
# ============================================

# 服务器配置（分站后端端口）
PORT=3001
NODE_ENV=production

# ⚠️ 重要：主站API地址（Mac后端地址）
# 方式1：使用内网穿透地址（推荐）
MAIN_SITE_API_URL=https://dump.dumpipa.com/api

# 方式2：使用Mac内网IP（如果分站服务器能访问Mac内网）
# MAIN_SITE_API_URL=http://192.168.1.100:8000/api

# 方式3：使用Mac公网IP（如果Mac有公网IP）
# MAIN_SITE_API_URL=http://your-mac-public-ip:8000/api

# 主站Token（分站的默认token，通常从数据库获取）
MAIN_SITE_TOKEN=

# 数据库配置（分站独立数据库）
DB_HOST=localhost
DB_PORT=3306
DB_USER=dumptest
DB_PASSWORD=Y5bWSzTWjRS4CbB2
DB_NAME=dumptest

# JWT配置（分站内部使用）
JWT_SECRET=site-backend-secret-key
JWT_EXPIRES_IN=7d

# CORS配置（分站前端域名）
CORS_ORIGIN=https://test.dumpipa.com,http://test.dumpipa.com

# 日志配置
LOG_LEVEL=info


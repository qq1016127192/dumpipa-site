# ============================================
# 方案B（通过主站前端代理）：分站后端对接主站前端域名
# 使用方法：复制此文件为 .env 并修改配置
# ============================================

# 服务器配置（分站后端端口）
PORT=3001
NODE_ENV=production

# ⚠️ 重要：主站API地址（通过主站前端域名，由 Nginx 代理到 Mac 后端）
# 使用 HTTPS（如果主站前端有SSL证书）
MAIN_SITE_API_URL=https://www.dumpipa.com/api

# 或使用 HTTP（如果主站前端没有SSL）
# MAIN_SITE_API_URL=http://www.dumpipa.com/api

# 主站Token（分站的默认token，通常从数据库获取）
MAIN_SITE_TOKEN=

# 数据库配置（分站独立数据库）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dumpipa_site

# JWT配置（分站内部使用）
JWT_SECRET=site-backend-secret-key
JWT_EXPIRES_IN=7d

# CORS配置（分站前端域名）
CORS_ORIGIN=https://site.dumpipa.com,http://site.dumpipa.com

# 日志配置
LOG_LEVEL=info

